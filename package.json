{
  "name": "sql-insert-editor",
  "displayName": "SQL Insert Editor",
  "version": "0.0.1",
  "description": "Helps in editing SQL insert statements.",
  "publisher": "ReneSaarsoo",
  "author": "Rene Saarsoo <nene@triin.net>",
  "license": "GPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sql"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sql-insert-editor.deleteColumn",
        "title": "Delete column"
      }
    ],
    "submenus": [
      {
        "id": "sql-insert-editor.submenu",
        "label": "SQL insert editor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "sql-insert-editor.submenu",
          "when": "editorLangId == sql",
          "group": "1_modification"
        }
      ],
      "sql-insert-editor.submenu": [
        {
          "command": "sql-insert-editor.deleteColumn"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "sql-parser-cst": "^0.42.1"
  }
}
